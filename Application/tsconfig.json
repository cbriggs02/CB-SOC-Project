{
  "compilerOptions": {
    "rootDir": "./src",
    "module": "node16",
    "moduleResolution": "node16",
    "target": "ES2020",
    "esModuleInterop": true,
    "verbatimModuleSyntax": false,
    "types": ["node"],
    "sourceMap": true,
    "strict": true,
    "skipLibCheck": true,
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true
  }
}
